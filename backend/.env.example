PORT=3000
MONGOOSE_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/streamify
STREAM_API_KEY=your_stream_api_key
STREAM_API_SECRET=your_stream_api_secret

JWT_SECRET_KEY=your_jwt_secret

NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Gmail SMTP — use App Password (NOT your regular Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM="Streamify <your.email@gmail.com>"

# Web Push (VAPID) — generate at https://web-push-codelab.glitch.me/
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@streamify.app

# Stream Chat Webhook — must match dashboard config
STREAM_WEBHOOK_SECRET=whsec_your_secret_here
